# App
NODE_ENV=production
LOG_LEVEL=info

# Traffic Config
DEFAULT_URL=https://lucasveneno.com/
MAX_SESSIONS=1
SESSION_TIME=3 # Minutes or 'random' (60-300s)

# Stealth & Behavior
HEADLESS=true
HUMAN_BEHAVIOR=true
BEHAVIOR_INTENSITY=medium # low, medium, high

# Browser Seeding
PERSISTENT_SESSIONS=false
SESSIONS_DATA_DIR=./sessions

# Proxy settings (optional)
PROXY_URL=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=
