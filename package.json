    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.4",
    "@types/minimist": "^1.2.2",
    "@types/node": "^20.5.6",
    "jest": "^29.6.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
